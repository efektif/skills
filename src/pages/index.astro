---
import "@efektif/tokens/theme.css";

const skillGroups = [
  {
    eyebrow: "Foundation",
    title: "Core Operating Loop",
    summary: "The skills that should shape almost every agent-led repo session.",
    accent: "mint",
    skills: [
      "efektif-repo-agent-setup",
      "efektif-repo-grounding",
      "efektif-memory-grounding",
      "efektif-clarify-with-evidence",
      "efektif-safe-implementation",
      "efektif-verification-before-done",
    ],
  },
  {
    eyebrow: "Engineering",
    title: "Build And Debug",
    summary: "Practical engineering workflows tuned for small, verified changes.",
    accent: "blue",
    skills: [
      "efektif-diagnose",
      "efektif-tdd",
      "efektif-user-workflow-qa",
      "efektif-crazy-story",
      "efektif-code-review",
      "efektif-refactor-plan",
      "efektif-architecture-review",
    ],
  },
  {
    eyebrow: "Planning",
    title: "Shape The Work",
    summary: "Turn rough intent into PRDs, issues, and execution slices.",
    accent: "amber",
    skills: [
      "efektif-intent-to-prd",
      "efektif-plan-to-issues",
      "efektif-prd-to-plan",
      "efektif-triage",
      "efektif-zoom-out",
    ],
  },
  {
    eyebrow: "Local Ops",
    title: "Agent Ops",
    summary: "Skills for local machines, deploy checks, commits, and continuation across agents.",
    accent: "coral",
    skills: [
      "efektif-deployment-readiness",
      "efektif-machine-cleanup",
      "efektif-checkpoint-commits",
      "efektif-branch-summary",
      "efektif-handoff",
      "efektif-install-skill-package",
      "efektif-write-skill",
    ],
  },
  {
    eyebrow: "Product",
    title: "Design And Prototype",
    summary: "Skills for UI decisions and small interactive artifacts.",
    accent: "blue",
    skills: ["efektif-design-interface", "efektif-prototype"],
  },
];

const buildOrder = [
  {
    step: "01",
    name: "efektif-repo-agent-setup",
    reason: "Gives every repo a local contract for docs, issue flow, and validation.",
    why: "All later skills need to know where repo guidance, domain context, validation commands, and issue tracking live.",
    changes: "Adds a repeatable setup contract so agents do not rediscover the same repo rules every session.",
    buildWhen: "Build first, before any other skill depends on repo-specific conventions.",
  },
  {
    step: "02",
    name: "efektif-repo-grounding",
    reason: "Stops generic answers by forcing file, script, and git-state inspection.",
    why: "Most user requests depend on the live checkout, not a generic framework answer.",
    changes: "Makes agents inspect files, scripts, branch state, and local commands before answering or editing.",
    buildWhen: "Build immediately after setup because it improves every repo question and implementation task.",
  },
  {
    step: "03",
    name: "efektif-memory-grounding",
    reason: "Uses prior agent context without pretending stale memory is current truth.",
    why: "This workflow spans Efektif, Pasco, VAP, and machine-local work where past decisions matter.",
    changes: "Separates memory-derived context from current verification, so stale facts do not become false certainty.",
    buildWhen: "Build once repo grounding exists, so memory can point the agent toward the right files without replacing inspection.",
  },
  {
    step: "04",
    name: "efektif-safe-implementation",
    reason: "Keeps patches scoped and protects uncommitted user work.",
    why: "The user often works in dirty worktrees and expects small, reversible edits.",
    changes: "Defines git checks, edit boundaries, verification expectations, and user-change protection.",
    buildWhen: "Build before any broad engineering skill that might modify code or docs.",
  },
  {
    step: "05",
    name: "efektif-verification-before-done",
    reason: "Makes done, blocked, and unverified status explicit before handoff.",
    why: "Build success, deploy success, and actual readiness are different states.",
    changes: "Forces final answers to name what was verified, what is inferred, and what remains blocked.",
    buildWhen: "Build before diagnose, deploy, QA, and review skills so every workflow has a clear finish line.",
  },
  {
    step: "06",
    name: "efektif-diagnose",
    reason: "Adds the systematic debug loop for hard failures and regressions.",
    why: "Recurring work includes runtime failures, deploy blockers, local tool issues, and integration bugs.",
    changes: "Adds a reproduce, minimize, hypothesize, instrument, fix, and regression-test loop.",
    buildWhen: "Build after the safety and verification skills so debugging stays disciplined and evidence-backed.",
  },
];

const principles = [
  "Inspect before answering.",
  "Prefer dry-run before apply.",
  "Commit only when requested.",
  "Keep output readable and short.",
];

const commands = [
  {
    label: "Validate Package",
    command: "bun run skills:validate\n./scripts/validate-skills.sh",
    note: "Checks skill metadata before publishing or installing.",
  },
  {
    label: "Preview Install",
    command: "bun run skills:install:dry\n./scripts/install.sh",
    note: "Shows the install target before any files are written.",
  },
  {
    label: "Build Docs",
    command: "bun run build",
    note: "Runs Astro diagnostics and produces the static documentation site.",
  },
  {
    label: "Install From GitHub",
    command: "npx skills@latest add efektif/skills",
    note: "Fast path for users who want to install from the published repo.",
  },
];

const heroCommandText = "npx skills@latest add efektif/skills\nbun run skills:install:dry";
const heroCommandDisplay = `npx skills@latest add efektif/skills
# install from GitHub

bun run skills:install:dry
# local dry run`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Efektif Skills redesign roadmap for agent-led engineering workflows."
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Efektif Skills</title>
    <style>
      :root {
        color-scheme: light;
        --bg: var(--ef-bg-canvas);
        --paper: var(--ef-bg-base);
        --ink: var(--ef-fg-primary);
        --muted: var(--ef-fg-muted);
        --line: var(--ef-border-default);
        --line-strong: var(--ef-border-strong);
        --soft: var(--ef-bg-subtle);
        --selected: var(--ef-bg-muted);
        --terminal-bg: var(--ef-bg-inverse);
        --terminal-fg: var(--ef-fg-on-inverse);
        --terminal-line: color-mix(in oklab, var(--terminal-fg) 14%, transparent);
        --terminal-soft: color-mix(in oklab, var(--terminal-fg) 8%, transparent);
        --terminal-hover: color-mix(in oklab, var(--terminal-fg) 14%, transparent);
        font-family: var(--ef-font-sans);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
      }

      a {
        color: inherit;
      }

      main {
        width: min(1160px, calc(100% - 32px));
        margin: 0 auto;
        padding: 28px 0 72px;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 2;
        display: flex;
        min-height: 56px;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        border-bottom: 1px solid var(--line);
        background: color-mix(in oklab, var(--bg) 96%, transparent);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 900;
      }

      .brand-mark {
        display: inline-flex;
        width: 28px;
        height: 28px;
        align-items: center;
        justify-content: center;
        border-radius: var(--ef-radius-md);
        background: var(--ink);
        color: var(--paper);
        font-size: 0.76rem;
        letter-spacing: 0;
        line-height: 1;
      }

      .brand-e {
        font-family: var(--ef-font-mono);
        font-weight: 900;
      }

      .brand-s {
        font-family: var(--ef-font-sans);
        font-weight: 950;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      nav a {
        border-radius: var(--ef-radius-md);
        padding: 8px 10px;
        color: var(--muted);
        font-size: 0.9rem;
        font-weight: 800;
        text-decoration: none;
      }

      nav a:hover {
        background: var(--soft);
        color: var(--ink);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.08fr) minmax(320px, 0.92fr);
        gap: 42px;
        align-items: center;
        padding: 72px 0 54px;
      }

      .eyebrow {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 900;
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        max-width: 780px;
        margin-bottom: 22px;
        font-size: clamp(2.6rem, 5vw, 4.4rem);
        letter-spacing: 0;
        line-height: 1;
      }

      .lede {
        max-width: 700px;
        margin-bottom: 28px;
        color: var(--muted);
        font-size: 1.15rem;
        line-height: 1.65;
      }

      .actions,
      .status-row,
      .chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .button,
      .pill {
        display: inline-flex;
        min-height: 42px;
        align-items: center;
        border-radius: var(--ef-radius-md);
        padding: 0 14px;
        font-weight: 900;
        text-decoration: none;
      }

      .button.primary {
        background: var(--ink);
        color: var(--paper);
      }

      .button.secondary,
      .pill {
        border: 1px solid var(--line);
        background: var(--paper);
      }

      .pill {
        min-height: 36px;
        color: var(--muted);
        font-size: 0.85rem;
      }

      .dashboard {
        display: grid;
        gap: 14px;
      }

      .panel {
        border: 1px solid var(--line);
        border-radius: var(--ef-radius-md);
        background: var(--paper);
        box-shadow: none;
      }

      .summary-panel {
        padding: 18px;
      }

      .meter {
        display: grid;
        gap: 8px;
        margin-top: 18px;
      }

      .meter-row {
        display: grid;
        grid-template-columns: 112px 1fr auto;
        gap: 10px;
        align-items: center;
        color: var(--muted);
        font-size: 0.88rem;
        font-weight: 800;
      }

      .track {
        height: 8px;
        overflow: hidden;
        border-radius: var(--ef-radius-md);
        background: var(--selected);
      }

      .fill {
        display: block;
        height: 100%;
        border-radius: inherit;
      }

      .fill.mint {
        width: 100%;
        background: var(--ink);
      }

      .fill.amber {
        width: 62%;
        background: var(--muted);
      }

      .fill.coral {
        width: 0%;
        background: var(--muted);
      }

      .terminal {
        overflow: hidden;
        background: var(--terminal-bg);
        color: var(--terminal-fg);
      }

      .terminal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 7px;
        border-bottom: 1px solid var(--terminal-line);
        padding: 12px 14px;
      }

      .window-dots {
        display: flex;
        gap: 7px;
      }

      .dot {
        width: 9px;
        height: 9px;
        border-radius: var(--ef-radius-md);
        background: var(--ef-fg-subtle);
      }

      .dot:nth-child(2) {
        background: var(--ef-fg-muted);
      }

      .dot:nth-child(3) {
        background: var(--ef-fg-secondary);
      }

      .copy-button {
        min-height: 30px;
        cursor: pointer;
        border: 1px solid var(--terminal-line);
        border-radius: var(--ef-radius-md);
        padding: 0 10px;
        background: var(--terminal-soft);
        color: var(--terminal-fg);
        font: inherit;
        font-size: 0.78rem;
        font-weight: 900;
      }

      .copy-button:hover {
        background: var(--terminal-hover);
      }

      .copy-button[data-copied="true"] {
        border-color: color-mix(in oklab, var(--terminal-fg) 38%, transparent);
        background: color-mix(in oklab, var(--terminal-fg) 20%, transparent);
      }

      pre {
        margin: 0;
        overflow: auto;
        padding: 18px;
        white-space: pre-wrap;
      }

      code {
        font-family: var(--ef-font-mono);
        font-size: 0.88rem;
        line-height: 1.65;
      }

      .section {
        padding-top: 56px;
      }

      .section-head {
        display: grid;
        grid-template-columns: minmax(0, 0.75fr) minmax(280px, 0.45fr);
        gap: 28px;
        align-items: end;
        margin-bottom: 22px;
      }

      h2 {
        margin-bottom: 0;
        font-size: clamp(2rem, 4.8vw, 4rem);
        line-height: 1;
      }

      .section-head p,
      .card p,
      .step p,
      .command-card p {
        color: var(--muted);
        line-height: 1.6;
      }

      .principles {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        overflow: hidden;
        border: 1px solid var(--line);
        border-radius: var(--ef-radius-md);
        background: var(--line);
      }

      .principles p {
        min-height: 110px;
        margin: 0;
        padding: 18px;
        background: var(--paper);
        font-weight: 900;
        line-height: 1.25;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .card {
        display: grid;
        gap: 18px;
        min-height: 310px;
        padding: 20px;
        transition:
          border-color 180ms ease;
      }

      .card:hover,
      .step:hover,
      .command-card:hover {
        border-color: var(--ink);
      }

      .card[data-accent="mint"] {
        background: var(--soft);
      }

      .card[data-accent="blue"] {
        background: var(--soft);
      }

      .card[data-accent="amber"] {
        background: var(--soft);
      }

      .card[data-accent="coral"] {
        background: var(--soft);
      }

      .card h3 {
        margin-bottom: 8px;
        font-size: 1.55rem;
        line-height: 1.05;
      }

      .card .eyebrow {
        margin-bottom: 10px;
        color: var(--muted);
      }

      .chips {
        align-content: start;
      }

      .chip {
        border: 1px solid var(--line);
        border-radius: var(--ef-radius-md);
        padding: 7px 10px;
        background: var(--paper);
        font-size: 0.84rem;
        font-weight: 850;
      }

      .timeline {
        display: grid;
        gap: 12px;
      }

      .step {
        overflow: hidden;
        transition:
          border-color 180ms ease;
      }

      .step summary {
        display: grid;
        grid-template-columns: 68px minmax(0, 1fr) auto;
        gap: 16px;
        align-items: start;
        cursor: pointer;
        list-style: none;
        padding: 18px;
      }

      .step summary::-webkit-details-marker {
        display: none;
      }

      .step-number {
        display: grid;
        width: 48px;
        height: 48px;
        place-items: center;
        border-radius: var(--ef-radius-md);
        background: var(--ink);
        color: var(--paper);
        font-weight: 950;
      }

      .step h3 {
        margin-bottom: 6px;
      }

      .step-toggle {
        display: grid;
        width: 34px;
        height: 34px;
        place-items: center;
        border: 1px solid var(--line);
        border-radius: var(--ef-radius-md);
        background: var(--paper);
        color: var(--muted);
        font-size: 1.2rem;
        font-weight: 900;
        line-height: 1;
      }

      .step[open] .step-toggle {
        background: var(--ink);
        color: var(--paper);
      }

      .step[open] .step-toggle::before {
        content: "-";
      }

      .step:not([open]) .step-toggle::before {
        content: "+";
      }

      .step-details {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        border-top: 1px solid var(--line);
        padding: 16px 18px 18px 86px;
      }

      .step-detail {
        border: 1px solid var(--line);
        border-radius: var(--ef-radius-md);
        padding: 14px;
        background: var(--soft);
      }

      .step-detail strong {
        display: block;
        margin-bottom: 6px;
        font-size: 0.84rem;
      }

      .commands {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }

      .command-card {
        padding: 18px;
        transition:
          border-color 180ms ease;
      }

      .command-card pre {
        margin: 14px 0;
        border-radius: var(--ef-radius-md);
        background: var(--terminal-bg);
        color: var(--terminal-fg);
      }

      .command-card .terminal {
        margin: 14px 0;
      }

      .command-card .terminal pre {
        margin: 0;
        border-radius: 0;
      }

      @media (max-width: 880px) {
        main {
          width: min(100% - 24px, 1160px);
          padding-bottom: 48px;
        }

        .topbar {
          position: static;
          align-items: flex-start;
          padding-bottom: 12px;
        }

        nav {
          justify-content: flex-end;
        }

        .hero,
        .section-head,
        .cards,
        .commands,
        .step-details {
          grid-template-columns: 1fr;
        }

        .hero {
          min-height: auto;
          padding: 36px 0 40px;
        }

        .principles {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 560px) {
        .topbar {
          display: grid;
        }

        nav {
          justify-content: flex-start;
        }

        h1 {
          font-size: 3rem;
        }

        .step summary {
          grid-template-columns: 1fr;
        }

        .step-details {
          padding-left: 18px;
        }

        .principles {
          grid-template-columns: 1fr;
        }
      }

    </style>
  </head>
  <body>
    <main>
      <header class="topbar">
        <a class="brand" href="#" aria-label="Efektif Skills home">
          <span class="brand-mark" aria-hidden="true">
            <span class="brand-e">E</span><span class="brand-s">S</span>
          </span>
          <span>Efektif Skills</span>
        </a>
        <nav aria-label="Page sections">
          <a href="#system">System</a>
          <a href="#build-order">Build order</a>
          <a href="#commands">Install</a>
        </nav>
      </header>

      <section class="hero" aria-labelledby="page-title">
        <div>
          <p class="eyebrow">Redesign roadmap</p>
          <h1 id="page-title">Better skills for real agent work.</h1>
          <p class="lede">
            Efektif Skills maps an agent-first workflow for local repo work:
            grounded inspection, memory-aware continuity, safe implementation,
            verified commits, and deployment readiness.
          </p>
          <div class="actions">
            <a class="button primary" href="#build-order">Start with build order</a>
            <a class="button secondary" href="#system">Explore skill buckets</a>
          </div>
        </div>

        <aside class="dashboard" aria-label="Package preview status">
          <div class="panel summary-panel">
            <p class="eyebrow">Active package</p>
            <div class="status-row">
              <span class="pill">Active skills: 27</span>
              <span class="pill">Docs: ready</span>
              <span class="pill">Install: dry-run first</span>
            </div>
            <div class="meter" aria-label="Readiness meters">
              <div class="meter-row">
                <span>Docs</span>
                <span class="track"><span class="fill mint"></span></span>
                <span>ready</span>
              </div>
              <div class="meter-row">
                <span>Skill map</span>
                <span class="track"><span class="fill mint"></span></span>
                <span>ready</span>
              </div>
              <div class="meter-row">
                <span>Skills</span>
                <span class="track"><span class="fill mint"></span></span>
                <span>ready</span>
              </div>
            </div>
          </div>

          <div class="panel terminal">
            <div class="terminal-header">
              <div class="window-dots" aria-hidden="true">
                <span class="dot"></span>
                <span class="dot"></span>
                <span class="dot"></span>
              </div>
              <button class="copy-button" type="button" data-copy-text={heroCommandText}>
                Copy
              </button>
            </div>
            <pre><code>{heroCommandDisplay}</code></pre>
          </div>
        </aside>
      </section>

      <section class="section" aria-labelledby="principles-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">Principles</p>
            <h2 id="principles-title">The behavior to encode.</h2>
          </div>
          <p>
            These are the habits the next skills should make automatic, without
            bloating every prompt.
          </p>
        </div>
        <div class="principles">
          {principles.map((principle) => <p>{principle}</p>)}
        </div>
      </section>

      <section class="section" id="system" aria-labelledby="system-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">Skill system</p>
            <h2 id="system-title">Four buckets, one workflow.</h2>
          </div>
          <p>
            The proposed set covers planning, implementation, review, and local
            operations. Each bucket has a clear job.
          </p>
        </div>

        <div class="cards">
          {
            skillGroups.map((group) => (
              <article class="panel card" data-accent={group.accent}>
                <div>
                  <p class="eyebrow">{group.eyebrow}</p>
                  <h3>{group.title}</h3>
                  <p>{group.summary}</p>
                </div>
                <div class="chips" aria-label={`${group.title} skills`}>
                  {group.skills.map((skill) => <span class="chip">{skill}</span>)}
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section" id="build-order" aria-labelledby="build-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">Build order</p>
            <h2 id="build-title">Start where it changes behavior fastest.</h2>
          </div>
          <p>
            The first six skills should improve almost every session before the
            larger planning and architecture set gets built.
          </p>
        </div>

        <div class="timeline">
          {
            buildOrder.map((item) => (
              <details class="panel step" open={item.step === "01"}>
                <summary>
                  <span class="step-number">{item.step}</span>
                  <div>
                    <h3>{item.name}</h3>
                    <p>{item.reason}</p>
                  </div>
                  <span class="step-toggle" aria-hidden="true"></span>
                </summary>
                <div class="step-details">
                  <div class="step-detail">
                    <strong>Why it matters</strong>
                    <p>{item.why}</p>
                  </div>
                  <div class="step-detail">
                    <strong>What it changes</strong>
                    <p>{item.changes}</p>
                  </div>
                  <div class="step-detail">
                    <strong>When to build</strong>
                    <p>{item.buildWhen}</p>
                  </div>
                </div>
              </details>
            ))
          }
        </div>
      </section>

      <section class="section" id="commands" aria-labelledby="commands-title">
        <div class="section-head">
          <div>
            <p class="eyebrow">Install</p>
            <h2 id="commands-title">Install with guardrails.</h2>
          </div>
          <p>
            Use the path that matches your workflow. Public installs can use
            `npx`, while local contributors can use `bun` or the raw
            shell scripts.
          </p>
        </div>

        <div class="commands">
          {
            commands.map((item) => (
              <article class="panel command-card">
                <h3>{item.label}</h3>
                <div class="terminal">
                  <div class="terminal-header">
                    <div class="window-dots" aria-hidden="true">
                      <span class="dot"></span>
                      <span class="dot"></span>
                      <span class="dot"></span>
                    </div>
                    <button class="copy-button" type="button" data-copy-text={item.command}>
                      Copy
                    </button>
                  </div>
                  <pre><code>{item.command}</code></pre>
                </div>
                <p>{item.note}</p>
              </article>
            ))
          }
        </div>
      </section>
    </main>
    <script>
      const copyButtons = document.querySelectorAll("[data-copy-text]");

      const copyText = async (text: string) => {
        if (!navigator.clipboard?.writeText) {
          throw new Error("Clipboard API is not available.");
        }

        await navigator.clipboard.writeText(text);
      };

      copyButtons.forEach((button) => {
        button.addEventListener("click", async () => {
          const text = button.getAttribute("data-copy-text") ?? "";
          try {
            await copyText(text);
            button.textContent = "Copied";
            button.setAttribute("data-copied", "true");
          } catch {
            button.textContent = "Select";
            button.setAttribute("data-copied", "true");
          }

          window.setTimeout(() => {
            button.textContent = "Copy";
            button.removeAttribute("data-copied");
          }, 1600);
        });
      });
    </script>
  </body>
</html>
