---
import "@efektif/tokens/theme.css";

const skillGroups = [
  {
    eyebrow: "Start Here",
    title: "Ground The Agent",
    summary: "Make the agent inspect the real checkout, use durable context, and ask better questions.",
    color: "mint",
    skills: [
      "efektif-repo-agent-setup",
      "efektif-repo-grounding",
      "efektif-memory-grounding",
      "efektif-clarify-with-evidence",
    ],
  },
  {
    eyebrow: "Build Safely",
    title: "Change With Guardrails",
    summary: "Keep edits scoped, protect user work, test the result, and leave a clean handoff.",
    color: "sky",
    skills: [
      "efektif-safe-implementation",
      "efektif-verification-before-done",
      "efektif-diagnose",
      "efektif-code-review",
      "efektif-handoff",
    ],
  },
  {
    eyebrow: "Think Clearly",
    title: "Shape Product Work",
    summary: "Turn rough ideas into PRDs, issues, refactor plans, and architecture reviews.",
    color: "lemon",
    skills: [
      "efektif-intent-to-prd",
      "efektif-plan-to-issues",
      "efektif-prd-to-plan",
      "efektif-refactor-plan",
      "efektif-architecture-review",
      "efektif-zoom-out",
    ],
  },
  {
    eyebrow: "Check Reality",
    title: "Audit And Operate",
    summary: "Run user workflow QA, Crazy Story audits, deploy checks, cleanup, and checkpoint commits.",
    color: "pink",
    skills: [
      "efektif-user-workflow-qa",
      "efektif-crazy-story",
      "efektif-deployment-readiness",
      "efektif-machine-cleanup",
      "efektif-checkpoint-commits",
      "efektif-branch-summary",
    ],
  },
  {
    eyebrow: "Make It Tangible",
    title: "Design, Prototype, Teach",
    summary: "Use product context to design interfaces, prototype flows, and write more skills.",
    color: "grape",
    skills: ["efektif-design-interface", "efektif-prototype", "efektif-write-skill", "efektif-install-skill-package"],
  },
];

const lessonCards = [
  {
    step: "01",
    title: "Inspect before guessing",
    text: "The skills nudge the agent to read files, scripts, docs, and git state before giving advice.",
  },
  {
    step: "02",
    title: "Ask only useful questions",
    text: "Ambiguity becomes a short evidence-backed question instead of a long questionnaire.",
  },
  {
    step: "03",
    title: "Make smaller changes",
    text: "Implementation skills bias toward scoped patches, dry-runs, and safe checkpoints.",
  },
  {
    step: "04",
    title: "Prove the result",
    text: "Done means tests, builds, smoke checks, or an honest blocker, not a confident shrug.",
  },
];

const demoRows = [
  ["User asks", "Audit this app with Crazy Story and keep a tracker."],
  ["Skill loads", "efektif-crazy-story"],
  ["Agent creates", "docs/crazy-story.md with feature, story, status, evidence columns"],
  ["Agent checks", "routes, UI flows, commands, logs, screenshots, and retest status"],
];

const promptExample = `Use efektif-crazy-story to audit this app.

Create docs/crazy-story.md, inventory every visible and code-backed feature, write one user story per feature, test each story, document errors, fix approved UX or logistics issues, then retest and update the tracker.`;

const installCommand = "npx skills@latest add efektif/skills";
const localCommand = "bun run skills:validate\nbun run skills:install:dry\nbun run skills:install";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Efektif Skills is a playful, practical skill pack that teaches coding agents how to inspect, plan, build, verify, and hand off real repo work."
    />
    <link rel="icon" href="/skills/favicon.svg" type="image/svg+xml" />
    <title>Efektif Skills</title>
    <style>
      :root {
        color-scheme: light;
        --cream: #fff3d7;
        --cream-2: #ffe7f6;
        --ink: #24123a;
        --muted: #715f87;
        --paper: rgba(255, 255, 255, 0.76);
        --paper-strong: rgba(255, 255, 255, 0.92);
        --line: rgba(36, 18, 58, 0.12);
        --shadow: 16px 20px 0 rgba(36, 18, 58, 0.08), 0 24px 54px rgba(97, 54, 169, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.85);
        --shadow-small: 8px 10px 0 rgba(36, 18, 58, 0.08), 0 16px 34px rgba(97, 54, 169, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.84);
        --grape: #7c4dff;
        --pink: #ff63b6;
        --mint: #54e0bf;
        --lemon: #ffe45f;
        --sky: #6ed6ff;
        --orange: #ff9f43;
        --radius-xl: 36px;
        --radius-lg: 28px;
        --radius-md: 18px;
        font-family: var(--ef-font-sans);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        min-width: 320px;
        margin: 0;
        overflow-x: hidden;
        background:
          radial-gradient(circle at 8% 12%, rgba(255, 99, 182, 0.48), transparent 28%),
          radial-gradient(circle at 88% 10%, rgba(84, 224, 191, 0.45), transparent 26%),
          radial-gradient(circle at 80% 74%, rgba(110, 214, 255, 0.42), transparent 28%),
          linear-gradient(135deg, var(--cream), var(--cream-2) 48%, #dff9ff);
        color: var(--ink);
      }

      body::before,
      body::after {
        position: fixed;
        z-index: -1;
        border-radius: 999px;
        content: "";
        filter: blur(2px);
        opacity: 0.72;
      }

      body::before {
        width: 260px;
        height: 260px;
        right: -80px;
        top: 210px;
        background: var(--lemon);
      }

      body::after {
        width: 210px;
        height: 210px;
        left: -70px;
        bottom: 110px;
        background: var(--mint);
      }

      a {
        color: inherit;
      }

      main {
        width: min(1180px, calc(100% - 32px));
        margin: 0 auto;
        padding: 20px 0 52px;
      }

      .topbar,
      .clay,
      .code-card,
      .footer {
        border: 1px solid var(--line);
        background: var(--paper);
        box-shadow: var(--shadow-small);
        backdrop-filter: blur(18px);
      }

      .topbar {
        position: sticky;
        top: 14px;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        border-radius: 999px;
        padding: 12px 14px 12px 16px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 950;
        text-decoration: none;
      }

      .brand-mark,
      .step-badge,
      .tiny-orb {
        display: inline-grid;
        place-items: center;
        border: 1px solid rgba(36, 18, 58, 0.1);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75), 6px 7px 0 rgba(36, 18, 58, 0.08);
      }

      .brand-mark {
        width: 42px;
        height: 42px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--lemon), var(--pink));
        color: var(--ink);
        font-family: var(--ef-font-mono);
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      nav a {
        border-radius: 999px;
        padding: 10px 13px;
        color: var(--muted);
        font-size: 0.92rem;
        font-weight: 850;
        text-decoration: none;
      }

      nav a:hover {
        background: rgba(255, 255, 255, 0.72);
        color: var(--ink);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.04fr) minmax(320px, 0.96fr);
        gap: 28px;
        align-items: center;
        padding: 72px 0 44px;
      }

      .hero-copy {
        position: relative;
      }

      .kicker,
      .eyebrow {
        margin: 0 0 14px;
        color: var(--muted);
        font-size: 0.78rem;
        font-weight: 950;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .kicker {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        border: 1px solid rgba(36, 18, 58, 0.12);
        border-radius: 999px;
        padding: 8px 12px;
        background: rgba(255, 255, 255, 0.56);
      }

      .tiny-orb {
        width: 14px;
        height: 14px;
        border-radius: 999px;
        background: var(--mint);
      }

      h1,
      h2,
      h3,
      p {
        margin-top: 0;
      }

      h1 {
        max-width: 820px;
        margin-bottom: 22px;
        font-size: clamp(3rem, 7vw, 6.8rem);
        letter-spacing: -0.07em;
        line-height: 0.88;
      }

      .highlight {
        display: inline-block;
        border-radius: 28px;
        padding: 0 0.08em 0.08em;
        background: linear-gradient(120deg, rgba(255, 228, 95, 0.92), rgba(255, 99, 182, 0.58));
        box-shadow: 10px 12px 0 rgba(36, 18, 58, 0.08);
      }

      .lede {
        max-width: 700px;
        margin-bottom: 28px;
        color: var(--muted);
        font-size: clamp(1.08rem, 2vw, 1.28rem);
        line-height: 1.65;
      }

      .actions,
      .pill-row,
      .skill-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .button,
      .pill,
      .copy-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 46px;
        border-radius: 999px;
        padding: 0 17px;
        font-weight: 950;
        text-decoration: none;
      }

      .button.primary {
        border: 2px solid var(--ink);
        background: var(--ink);
        color: white;
        box-shadow: 7px 8px 0 rgba(36, 18, 58, 0.18);
      }

      .button.secondary {
        border: 2px solid rgba(36, 18, 58, 0.14);
        background: rgba(255, 255, 255, 0.72);
        color: var(--ink);
      }

      .button:hover,
      .copy-button:hover {
        transform: translateY(-1px);
      }

      button.button {
        cursor: pointer;
        font: inherit;
      }

      .pill-row {
        margin-top: 18px;
      }

      .pill {
        min-height: 38px;
        border: 1px solid rgba(36, 18, 58, 0.1);
        background: rgba(255, 255, 255, 0.62);
        color: var(--muted);
        font-size: 0.9rem;
      }

      .hero-demo {
        position: relative;
        min-height: 610px;
        border-radius: 44px;
        padding: 20px;
        background:
          radial-gradient(circle at 82% 12%, rgba(255, 228, 95, 0.74), transparent 30%),
          radial-gradient(circle at 18% 82%, rgba(84, 224, 191, 0.68), transparent 32%),
          rgba(255, 255, 255, 0.48);
        box-shadow: var(--shadow);
      }

      .demo-window {
        position: relative;
        display: grid;
        gap: 16px;
        height: 100%;
        border-radius: 34px;
        padding: 18px;
        background: rgba(255, 255, 255, 0.76);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }

      .demo-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .traffic {
        display: flex;
        gap: 7px;
      }

      .traffic span {
        width: 13px;
        height: 13px;
        border-radius: 999px;
        background: var(--pink);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.7);
      }

      .traffic span:nth-child(2) {
        background: var(--lemon);
      }

      .traffic span:nth-child(3) {
        background: var(--mint);
      }

      .demo-label {
        border-radius: 999px;
        padding: 7px 10px;
        background: rgba(124, 77, 255, 0.12);
        color: var(--grape);
        font-size: 0.78rem;
        font-weight: 950;
      }

      .chat-card {
        display: grid;
        gap: 8px;
        border-radius: 26px;
        padding: 18px;
        background: #fff8e8;
        box-shadow: 10px 12px 0 rgba(36, 18, 58, 0.07);
      }

      .chat-card.agent {
        margin-left: 48px;
        background: #effbff;
      }

      .chat-card strong {
        font-size: 0.84rem;
      }

      .chat-card p {
        margin-bottom: 0;
        color: var(--muted);
        line-height: 1.5;
      }

      .demo-grid {
        display: grid;
        gap: 10px;
      }

      .demo-row {
        display: grid;
        grid-template-columns: 110px minmax(0, 1fr);
        gap: 10px;
        align-items: center;
        border-radius: 20px;
        padding: 12px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: inset 0 0 0 1px rgba(36, 18, 58, 0.07);
      }

      .demo-row span:first-child {
        color: var(--muted);
        font-size: 0.82rem;
        font-weight: 950;
      }

      .demo-row span:last-child {
        font-weight: 850;
        line-height: 1.35;
      }

      .floating-note {
        position: absolute;
        right: -18px;
        bottom: 34px;
        max-width: 210px;
        transform: rotate(4deg);
        border-radius: 24px;
        padding: 16px;
        background: var(--lemon);
        box-shadow: 11px 13px 0 rgba(36, 18, 58, 0.12);
        font-size: 0.92rem;
        font-weight: 900;
        line-height: 1.35;
      }

      .section {
        padding: 54px 0 0;
      }

      .section-head {
        display: grid;
        grid-template-columns: minmax(0, 0.78fr) minmax(280px, 0.42fr);
        gap: 24px;
        align-items: end;
        margin-bottom: 22px;
      }

      h2 {
        margin-bottom: 0;
        font-size: clamp(2.25rem, 5vw, 4.9rem);
        letter-spacing: -0.06em;
        line-height: 0.92;
      }

      .section-head p,
      .lesson-card p,
      .skill-card p,
      .cta-panel p,
      .code-card p {
        color: var(--muted);
        line-height: 1.6;
      }

      .lesson-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
      }

      .lesson-card,
      .skill-card,
      .cta-panel {
        border-radius: var(--radius-xl);
        padding: 22px;
      }

      .lesson-card {
        min-height: 260px;
      }

      .lesson-card:nth-child(1) {
        background: rgba(84, 224, 191, 0.44);
      }

      .lesson-card:nth-child(2) {
        background: rgba(110, 214, 255, 0.42);
      }

      .lesson-card:nth-child(3) {
        background: rgba(255, 228, 95, 0.52);
      }

      .lesson-card:nth-child(4) {
        background: rgba(255, 99, 182, 0.34);
      }

      .step-badge {
        width: 54px;
        height: 54px;
        margin-bottom: 38px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.7);
        font-family: var(--ef-font-mono);
        font-weight: 950;
      }

      .lesson-card h3,
      .skill-card h3,
      .code-card h3,
      .cta-panel h2 {
        margin-bottom: 10px;
        letter-spacing: -0.03em;
        line-height: 1;
      }

      .playground {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1.1fr);
        gap: 18px;
      }

      .code-card {
        overflow: hidden;
        border-radius: var(--radius-xl);
      }

      .code-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        border-bottom: 1px solid rgba(36, 18, 58, 0.1);
        padding: 16px 18px;
      }

      .copy-button {
        min-height: 34px;
        cursor: pointer;
        border: 0;
        background: var(--ink);
        color: white;
        font: inherit;
        font-size: 0.8rem;
      }

      .copy-button[data-copied="true"] {
        background: var(--mint);
        color: var(--ink);
      }

      pre {
        margin: 0;
        overflow: auto;
        padding: 18px;
        white-space: pre-wrap;
      }

      code {
        font-family: var(--ef-font-mono);
        font-size: 0.9rem;
        line-height: 1.7;
      }

      .code-card pre {
        background: rgba(36, 18, 58, 0.94);
        color: #fff8e8;
      }

      .demo-outcome {
        display: grid;
        gap: 14px;
      }

      .outcome-item {
        border-radius: 26px;
        padding: 18px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: var(--shadow-small);
      }

      .outcome-item strong {
        display: block;
        margin-bottom: 8px;
      }

      .outcome-item p {
        margin-bottom: 0;
        color: var(--muted);
        line-height: 1.55;
      }

      .skills-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .skill-card {
        position: relative;
        overflow: hidden;
        min-height: 320px;
      }

      .skill-card::before {
        position: absolute;
        right: -44px;
        top: -44px;
        width: 150px;
        height: 150px;
        border-radius: 999px;
        content: "";
        opacity: 0.68;
      }

      .skill-card[data-color="mint"]::before {
        background: var(--mint);
      }

      .skill-card[data-color="sky"]::before {
        background: var(--sky);
      }

      .skill-card[data-color="lemon"]::before {
        background: var(--lemon);
      }

      .skill-card[data-color="pink"]::before {
        background: var(--pink);
      }

      .skill-card[data-color="grape"]::before {
        background: var(--grape);
      }

      .skill-chips {
        position: relative;
        margin-top: 22px;
      }

      .chip {
        border: 1px solid rgba(36, 18, 58, 0.09);
        border-radius: 999px;
        padding: 8px 11px;
        background: rgba(255, 255, 255, 0.72);
        color: var(--ink);
        font-size: 0.84rem;
        font-weight: 850;
      }

      .install-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 18px;
      }

      .cta-panel {
        display: grid;
        grid-template-columns: minmax(0, 0.82fr) auto;
        gap: 20px;
        align-items: center;
        margin-top: 18px;
        background:
          radial-gradient(circle at 85% 18%, rgba(255, 228, 95, 0.86), transparent 26%),
          radial-gradient(circle at 15% 90%, rgba(84, 224, 191, 0.58), transparent 30%),
          rgba(255, 255, 255, 0.72);
      }

      .cta-panel h2 {
        font-size: clamp(2rem, 4vw, 4rem);
      }

      .footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        margin-top: 54px;
        border-radius: 999px;
        padding: 14px 18px;
        color: var(--muted);
        font-weight: 850;
      }

      .footer a {
        color: var(--ink);
        font-weight: 950;
      }

      @media (max-width: 960px) {
        main {
          width: min(100% - 24px, 1180px);
        }

        .topbar {
          position: static;
          border-radius: 28px;
        }

        .hero,
        .section-head,
        .playground,
        .install-grid,
        .cta-panel {
          grid-template-columns: 1fr;
        }

        .hero {
          padding-top: 48px;
        }

        .hero-demo {
          min-height: auto;
        }

        .lesson-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .floating-note {
          position: static;
          max-width: none;
          transform: none;
        }
      }

      @media (max-width: 680px) {
        .topbar,
        .footer {
          align-items: flex-start;
          border-radius: 26px;
          flex-direction: column;
        }

        nav {
          width: 100%;
        }

        nav a {
          background: rgba(255, 255, 255, 0.52);
        }

        h1 {
          font-size: clamp(3.2rem, 18vw, 4.4rem);
        }

        .lesson-grid,
        .skills-grid {
          grid-template-columns: 1fr;
        }

        .demo-row {
          grid-template-columns: 1fr;
        }

        .chat-card.agent {
          margin-left: 0;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topbar">
        <a class="brand" href="#" aria-label="Efektif Skills home">
          <span class="brand-mark" aria-hidden="true">ES</span>
          <span>Efektif Skills</span>
        </a>
        <nav aria-label="Page sections">
          <a href="#learn">Learn</a>
          <a href="#demo">Demo</a>
          <a href="#skills">Skills</a>
          <a href="#install">Install</a>
        </nav>
      </header>

      <section class="hero" aria-labelledby="page-title">
        <div class="hero-copy">
          <p class="kicker"><span class="tiny-orb" aria-hidden="true"></span> Agent skills that teach by doing</p>
          <h1 id="page-title">Give your coding agent a <span class="highlight">workshop brain.</span></h1>
          <p class="lede">
            Efektif Skills is a colorful little curriculum for repo work. It teaches agents to inspect first, ask smarter questions, make smaller changes, verify the result, and hand off cleanly.
          </p>
          <div class="actions">
            <a class="button primary" href="#install">Install the skills</a>
            <a class="button secondary" href="#prompt">Try the prompt</a>
          </div>
          <div class="pill-row" aria-label="Package facts">
            <span class="pill">27 tiny skills</span>
            <span class="pill">Dry-run friendly</span>
            <span class="pill">Built for real repos</span>
          </div>
        </div>

        <aside class="hero-demo" aria-label="Efektif Skills demo preview">
          <div class="demo-window">
            <div class="demo-top">
              <div class="traffic" aria-hidden="true"><span></span><span></span><span></span></div>
              <span class="demo-label">Skill classroom</span>
            </div>
            <div class="chat-card">
              <strong>User</strong>
              <p>Can you audit this app and tell me what is actually working?</p>
            </div>
            <div class="chat-card agent">
              <strong>Agent using Efektif Skills</strong>
              <p>I will load the Crazy Story audit, create one tracker, test every story, document evidence, and only fix approved UX or logistics issues.</p>
            </div>
            <div class="demo-grid">
              {demoRows.map(([label, value]) => (
                <div class="demo-row">
                  <span>{label}</span>
                  <span>{value}</span>
                </div>
              ))}
            </div>
          </div>
